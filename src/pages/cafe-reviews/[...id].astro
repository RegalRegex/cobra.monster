---
import CoffeeShopReviewLayout from "@layouts/CoffeeShopReviewLayout.astro";
import type { GetStaticPaths } from "astro";
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import { getCollection } from "astro:content";
export const getStaticPaths = (async () => {
  const reviewEntries = await getCollection("coffeeShopReviews");
  return reviewEntries.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

interface Props {
  entry: CollectionEntry<"coffeeShopReviews">;
}
const { entry } = Astro.props;
const { Content } = await render(entry);
---

<CoffeeShopReviewLayout cafeCollectionItem={entry}>
  <Content />
</CoffeeShopReviewLayout>
