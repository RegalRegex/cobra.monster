---
import type { GetStaticPaths, MarkdownHeading } from "astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import AboutBlurbLayout from "@layouts/AboutBlurbLayout.astro";
import { render } from "astro:content";

export const getStaticPaths = (async () => {
  const blurbs = await getCollection("aboutBlurbs");
  const headings = await Promise.all(
    blurbs.map(async (blurb) => {
      const data = await render(blurb);
      return data.headings;
    }),
  );
  return blurbs.map((blurb, index) => ({
    params: { id: blurb.id },
    props: { blurb, headings: headings[index] },
  }));
}) satisfies GetStaticPaths;

interface Props {
  blurb: CollectionEntry<"aboutBlurbs">;
  headings: MarkdownHeading[];
}
const { blurb, headings } = Astro.props;
const { Content } = await render(blurb);
---

<AboutBlurbLayout blurb={blurb} headings={headings}>
  <Content />
</AboutBlurbLayout>
