---
import BlogAboutMe from "@components/BlogAboutMe.astro";
import ChiStarHorizontalRule from "@components/ImageComponents/ChiStarHorizontalRule.astro";
import ScrollToNav from "@components/ScrollToNav.astro";

/**
 * Template to re-use blog formatting and custom prose-edits that I've made to Tailwind's Prose package
 */
---

<article class="mx-4 2xl:mx-52 lg:mx-44 md:mx-4 md:mt-28 mt-8">
  <header class="flex flex-col md:grid grid-cols-12 md:border-0 border-slate-200 md:mb-0 md:pb-0 mb-2">
    <div class="col-span-12 md:mb-10 mb-5">
      <slot name="header" />
    </div>
  </header>
  <div class="text-xl text-slate-200 md:grid grid-cols-12 gap-10 flex flex-col">
    <ScrollToNav left={true} />
    <aside class="col-start-1 col-span-4">
      <slot name="aside" />
    </aside>
    <main
      class:list={[
        `prose 
        3xl:mx-32 md:mx-0 sm:mx-24 col-span-8 
        md:prose-lg 
        prose-slate prose-invert 
        prose-blockquote:border-yellow prose-blockquote:border-l-8 prose-blockquote:bg-redDark/40 prose-blockquote:font-light prose-blockquote:pr-2
        prose-hr:border-slate-200 
        prose-h5:font-bold prose-h5:text-white prose-h6:font-bold prose-h6:text-white 
        prose-code:bg-black/35 
        prose-li:has-[ul]:list-none prose-ul:before:text-white 
        prose-thead:border-slate-200 prose-tr:border-slate-200 
        prose-a:hover:no-underline`,
      ]}
    >
      <slot name="main" />
      <ChiStarHorizontalRule />
    </main>
    <div class="xl:col-start-5 xl:col-span-8 col-start-1 col-span-12">
      <BlogAboutMe />
    </div>
  </div>
</article>
