---
import type { MarkdownHeading } from "astro";
import TextDeco from "@components/TextDeco.astro";
import ChiStar from "@components/ImageComponents/ChiStar.astro";

interface Props {
  headings: MarkdownHeading[];
}
const { headings } = Astro.props;
const filteredHeadings = headings.filter((heading) => heading.text !== "Footnotes");
---

<nav class="sticky z-1 top-0 pt-4 pl-2 mb-2 mr-5 flex flex-col" id="table-of-contents-nav">
  <h3 class="text-3xl font-medium mb-2">Contents</h3>
  <ul class="md:max-h-[85vh]" id="table-of-contents-list">
    {
      filteredHeadings.map((heading, i, arr) => {
        if (heading.depth > 1) {
          return (
            <li class="my-1 last-of-type:border-b-4 border-yellow has-[+.buffer]:pb-2 text-amber-300">
              <div class="flex items-start gap-2">
                <span class="text-sm items-center mt-1.5 ">
                  {[...Array(heading.depth - 1)].map(() => (
                    <ChiStar />
                  ))}
                </span>
                <a class="hover:no-underline underline decoration-amber-400 decoration-1 cursor-pointer font-light text-wrap" href={`#${heading.slug}`}>
                  <span class={`text-wrap`}>{heading.text}</span>
                </a>
              </div>
            </li>
          );
        }
        return (
          // Divider element. Separates top level headers. "arr" avoids line when multiple top-level headers in sequence
          // <div class:list={[" w-[95%]  bg-slate-200/30 p-0.5 mb-1.5", `${(i===0 || arr[i-1].depth === 1) ? 'hidden' :'inline-block'}`]}></div>
          <li
            class={`last-of-type:border-b-4 last-of-type:border-b-yellow ${i === 0 || arr[i - 1].depth === 1 ? "" : "border-t-slate-200/30 pt-2 border-t-4 buffer"}`}
          >
            <a
              class="hover:no-underline underline decoration-amber-400 decoration-1 cursor-pointer text-amber-300 font-light text-wrap"
              href={`#${heading.slug}`}
            >
              {heading.text}
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>
